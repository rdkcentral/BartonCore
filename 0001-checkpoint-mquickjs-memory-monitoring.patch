     JS_PushArg(ctx, jsonArg);
@@ -262,11 +268,14 @@ bool SbmdScriptImpl::ExecuteScript(const std::string &script,
     JSValue scriptResult = JS_Call(ctx, 1);
     if (JS_IsException(scriptResult))
