Date: Thu, 19 Mar 2026 19:13:57 +0000
Subject: [PATCH] checkpoint mquickjs memory monitoring

---
 .../matter/sbmd/mquickjs/MQuickJsRuntime.cpp  |  46 ++++-
 .../matter/sbmd/mquickjs/MQuickJsRuntime.h    |   7 +
 .../matter/sbmd/mquickjs/SbmdScriptImpl.cpp   |  13 +-
 .../matter/sbmd/mquickjs/SbmdUtilsLoader.cpp  |   1 +
 core/test/src/SbmdScriptTest.cpp              | 171 ++++++++++++++++++
 docker/Dockerfile                             |   1 +
 .../mquickjs/0001-add-memory-usage-api.patch  |  74 ++++++++
 7 files changed, 310 insertions(+), 3 deletions(-)
 create mode 100644 docker/patches/mquickjs/0001-add-memory-usage-api.patch

diff --git a/core/deviceDrivers/matter/sbmd/mquickjs/MQuickJsRuntime.cpp b/core/deviceDrivers/matter/sbmd/mquickjs/MQuickJsRuntime.cpp
index 34c76ea1..7a470fcd 100644
--- a/core/deviceDrivers/matter/sbmd/mquickjs/MQuickJsRuntime.cpp
+++ b/core/deviceDrivers/matter/sbmd/mquickjs/MQuickJsRuntime.cpp
@@ -52,6 +52,7 @@ size_t MQuickJsRuntime::memSize = 0;
 JSContext *MQuickJsRuntime::ctx = nullptr;
 std::mutex MQuickJsRuntime::mutex;
 bool MQuickJsRuntime::initialized = false;
+size_t MQuickJsRuntime::peakHeapUsed = 0;
 
 namespace
 {
@@ -123,7 +124,14 @@ bool MQuickJsRuntime::Initialize(size_t memorySize)
     JSValue urlResult = JS_Eval(ctx, urlPolyfill, strlen(urlPolyfill), "<url-polyfill>", JS_EVAL_REPL);
     if (JS_IsException(urlResult))
     {
-        icWarn("Failed to install URL polyfill: %s", GetExceptionString(ctx).c_str());
+        icError("Failed to install URL polyfill: %s", GetExceptionString(ctx).c_str());
+        LogMemoryUsage("polyfill-failed");
+        JS_FreeContext(ctx);
+        ctx = nullptr;
+        free(memBuffer);
+        memBuffer = nullptr;
+        memSize = 0;
+        return false;
     }
 
     // Check if polyfill installation left an exception
@@ -134,6 +142,7 @@ bool MQuickJsRuntime::Initialize(size_t memorySize)
     }
 
     initialized = true;
+    LogMemoryUsage("post-init (context + stdlib + polyfills)");
     icInfo("Shared mquickjs context initialized successfully");
     return true;
 }
@@ -263,4 +272,39 @@ bool MQuickJsRuntime::CheckAndClearPendingException(JSContext *ctx, std::string
     return true;
 }
 
+void MQuickJsRuntime::LogMemoryUsage(const char *label)
+{
+    if (!ctx)
+    {
+        return;
+    }
+
+    JSMemoryUsage usage;
+    if (JS_GetMemoryUsage(ctx, &usage) != 0)
+    {
+        icWarn("Failed to get mquickjs memory usage at '%s'", label);
+        return;
+    }
+
+    // Net heap = heap region minus free blocks reclaimed by GC
+    size_t netHeapUsed = usage.heap_used - usage.heap_free_blocks;
+
+    if (netHeapUsed > peakHeapUsed)
+    {
+        peakHeapUsed = netHeapUsed;
+    }
+
+    icInfo("[%s] mquickjs memory: arena=%zu heap=%zu (net=%zu, free_blocks=%zu) "
+           "stack=%zu free_gap=%zu overhead=%zu peak_heap=%zu",
+           label,
+           usage.arena_size,
+           usage.heap_used,
+           netHeapUsed,
+           usage.heap_free_blocks,
+           usage.stack_used,
+           usage.free_size,
+           usage.overhead,
+           peakHeapUsed);
+}
+
 } // namespace barton
diff --git a/core/deviceDrivers/matter/sbmd/mquickjs/MQuickJsRuntime.h b/core/deviceDrivers/matter/sbmd/mquickjs/MQuickJsRuntime.h
index 5e1f68a8..6377c5c8 100644
--- a/core/deviceDrivers/matter/sbmd/mquickjs/MQuickJsRuntime.h
+++ b/core/deviceDrivers/matter/sbmd/mquickjs/MQuickJsRuntime.h
@@ -115,12 +115,19 @@ namespace barton
          */
         static bool CheckAndClearPendingException(JSContext *ctx, std::string *outExceptionMsg = nullptr);
 
+        /**
+         * Log current mquickjs memory usage at the given label.
+         * Also updates peak tracking. Thread-safe (caller must hold mutex).
+         */
+        static void LogMemoryUsage(const char *label);
+
     private:
         static uint8_t *memBuffer;
         static size_t memSize;
         static JSContext *ctx;
         static std::mutex mutex;
         static bool initialized;
+        static size_t peakHeapUsed;
     };
 
 } // namespace barton
