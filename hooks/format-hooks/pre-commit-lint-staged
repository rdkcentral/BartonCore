# Formats staged files that Prettier owns (JavaScript) via lint-staged. See
# .lintstagedrc.json for the file globs and .prettierrc.yaml for the style.
# The file sets are disjoint from the clang-format hook, so the two formatters
# never conflict.

set -e

REPO_ROOT=$(git rev-parse --show-toplevel)

# The pre-commit hook is shared across all worktrees, but the lint-staged config
# only exists on branches that opt in. Skip cleanly when it is absent so commits
# on other branches are not blocked.
shopt -s nullglob
lintStagedConfigs=( "${REPO_ROOT}"/.lintstagedrc* "${REPO_ROOT}"/lint-staged.config.* )
shopt -u nullglob

if [ ${#lintStagedConfigs[@]} -eq 0 ]; then
    exit 0
fi

if command -v lint-staged >/dev/null 2>&1; then
    ( cd "${REPO_ROOT}" && lint-staged )
else
    echo "pre-commit: 'lint-staged' not found on PATH; skipping the Prettier step." >&2
    echo "            Install it (see docker/Dockerfile.devcontainer) to format JavaScript on commit." >&2
fi
