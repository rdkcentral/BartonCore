notice() {
    echo "-- $0: $@"
}

set -e

if [ -f /.dockerenv ]; then
    echo "ERROR: dockerw is already running inside a container."
    echo "Run commands directly in the current container instead of nesting containers."
    exit 1
fi

COMPOSE_INTERACTIVE_FLAGS=""
EXTRA_ENV="-e SSH_AUTH_SOCK"
DEV_VOL=""
HOST_NETWORK=""
OBSERVABILITY_COMPOSE=""

while getopts ":ne:dHo" opt; do
    case ${opt} in
    n) # process option n
        COMPOSE_INTERACTIVE_FLAGS="--no-TTY"
        ;;
    e) # extra environment variables
        EXTRA_ENV="${EXTRA_ENV} -e ${OPTARG}"
        ;;
    d) # add /dev volume mapping
        DEV_VOL="-v /dev:/dev"
        ;;
    H) # use host networking (useful for Matter device access)
        HOST_NETWORK="--network host"
        ;;
    o) # include observability services (OTel Collector + Jaeger)
        OBSERVABILITY_COMPOSE="true"
        ;;
    esac
done
shift "$(($OPTIND - 1))"

DIR=$(pwd)

# generate the `docker/.env` file and ensure the network/image is created
$DIR/docker/setupDockerEnv.sh

COMPOSE_ARGS="-f ${DIR}/docker/compose.yaml"

if [ "${OBSERVABILITY_COMPOSE}" = "true" ]; then
    COMPOSE_ARGS="${COMPOSE_ARGS} -f ${DIR}/docker/compose.observability.yaml"

    # Create a temporary override that publishes Jaeger on an ephemeral host
    # port. The devcontainer uses socat instead, so compose.observability.yaml
    # itself has no ports: section.
    OTEL_OVERRIDE=$(mktemp /tmp/compose-otel-ports.XXXXXX.yaml)
    cat > "${OTEL_OVERRIDE}" <<'EOF'
services:
    jaeger:
        ports:
            - "16686"
EOF
    COMPOSE_ARGS="${COMPOSE_ARGS} -f ${OTEL_OVERRIDE}"

    cleanup_observability() {
        docker compose ${COMPOSE_ARGS} down otel-collector jaeger 2>/dev/null
        rm -f "${OTEL_OVERRIDE}"
    }
    trap cleanup_observability EXIT

    # Start observability infrastructure before the barton service
    docker compose ${COMPOSE_ARGS} up -d otel-collector jaeger

    JAEGER_URL=$(docker compose ${COMPOSE_ARGS} port jaeger 16686 2>/dev/null)
    if [ -n "${JAEGER_URL}" ]; then
        notice "Jaeger UI available at http://${JAEGER_URL}"
    fi
fi

EXTRA_VOLUMES="${DEV_VOL}"

VOLUMES_ARGS="-v $HOME:$HOME
             $EXTRA_VOLUMES"

# create a unique container name prefixed with the user id, useful when on a shared machine
USER_ID=$(id -u -n)
RANDOM_NUMBER=$(shuf -i 100000-999999 -n 1)
CONTAINER_NAME="${USER_ID}_${RANDOM_NUMBER}"

docker compose ${COMPOSE_ARGS} run \
    --rm \
    --name ${CONTAINER_NAME} \
    ${COMPOSE_INTERACTIVE_FLAGS} \
    ${HOST_NETWORK} \
    --workdir "${DIR}" \
    ${VOLUMES_ARGS} \
    ${EXTRA_ENV} \
    barton \
    $*
